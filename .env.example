DATABASE_URL=mysql://labor_app:labor_app_password@127.0.0.1:3306/labor_insurance
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated emails that may test paid exports locally.
DEV_PREMIUM_EMAILS=

# Initial administrator emails. Database role=admin is also accepted.
ADMIN_EMAILS=

# 申告助手。OpenAI Platform API keyをサーバー環境だけに設定してください。
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra

# Stripe: never commit real keys. Prefer a restricted key (rk_) with only the
# permissions required by Checkout, Billing, Customers and Customer Portal.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
FREE_EXPORT_CREDITS=3
STRIPE_EXPORT_PACK_5_PRICE_ID=
STRIPE_EXPORT_PACK_20_PRICE_ID=
STRIPE_EXPORT_PACK_50_PRICE_ID=

# Enable only after the required Japanese tax registration is active in Stripe.
STRIPE_AUTOMATIC_TAX_ENABLED=false
